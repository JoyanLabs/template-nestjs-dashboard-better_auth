# =============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================================================
API_PREFIX=api
ENABLE_EXPERIMENTAL_COREPACK=1
LOGGER_LEVEL=log
NODE_ENV=development
PORT=3001
SKIP_TESTS=false

# =============================================================================
# BASE DE DATOS
# =============================================================================
# IMPORTANTE: Para Docker Compose usa "postgres" como host
#             Para desarrollo local usa "localhost"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db?schema=public

# Variables de PostgreSQL (requeridas por docker-compose.yml)
POSTGRES_DB=app_db
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres

# =============================================================================
# AUTENTICACIÓN - BETTER AUTH
# =============================================================================
# Lista separada por comas de orígenes permitidos para CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Secret para firmar tokens (mínimo 32 caracteres) - CAMBIA ESTO EN PRODUCCIÓN
BETTER_AUTH_SECRET=your-better-auth-secret-at-least-32-chars

# URL base de Better Auth - debe coincidir con tu dominio/puerto
BETTER_AUTH_URL=http://localhost:3001

# Secret para JWT (mínimo 16 caracteres) - CAMBIA ESTO EN PRODUCCIÓN
JWT_SECRET=your-jwt-secret-at-least-32-characters

# =============================================================================
# INNGEST (Tareas asíncronas)
# =============================================================================
# Modo desarrollo (1 = activado, 0 = desactivado)
INNGEST_DEV=1

# URL del servidor de Inngest (para desarrollo local)
# INNGEST_BASE_URL=http://localhost:8288

# Claves para producción (no necesarias en desarrollo)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# =============================================================================
# MAILTRAP (Servicio de Email - Opcional)
# =============================================================================
# Obtén tu token de API en https://mailtrap.io/
# MAILTRAP_API_TOKEN=your-mailtrap-api-token
# MAILTRAP_SENDER_EMAIL=hello@example.com
# MAILTRAP_SENDER_NAME="My App"
# MAILTRAP_SANDBOX=true
# MAILTRAP_INBOX_ID=123456

# =============================================================================
# CLOUDFLARE R2 (Storage - Opcional)
# =============================================================================
# Configura estas variables para usar Cloudflare R2 como storage
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://your-domain.com

# =============================================================================
# FRONTEND URL
# =============================================================================
# URL base del frontend (para redirects de autenticación)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# USUARIO ADMINISTRADOR AUTOMÁTICO
# =============================================================================
# Configuración del usuario administrador creado automáticamente al iniciar
# Si no se especifica, usa los valores por defecto:
#   - Email: admin@admin.com
#   - Password: Password123!
#   - Name: Administrador

# ADMIN_EMAIL=admin@admin.com
# ADMIN_PASSWORD=Password123!
# ADMIN_NAME=Administrador

# =============================================================================
# API PERU - VALIDACIÓN RUC
# =============================================================================
# Token de API Perú para consulta de RUC (obtener en https://apiperu.dev)
# Solo para proyectos Perú
# API_PERU_TOKEN=tu_token_aqui

# =============================================================================
# ENDPOINTS PÚBLICOS
# =============================================================================
# Habilitar endpoints públicos de validación (ruc, cui)
# Default: false (más seguro)
# ENABLE_PUBLIC_VALIDATION_ENDPOINTS=false
