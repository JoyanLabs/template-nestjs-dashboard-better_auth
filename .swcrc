{
	"$schema": "https://swc.rs/schema.json",
	"sourceMaps": true,
	"jsc": {
		"parser": {
			"syntax": "typescript",
			"decorators": true,
			"dynamicImport": true
		},
		"transform": {
			"legacyDecorator": true,
			"decoratorMetadata": true
		},
		"target": "es2022",
		"keepClassNames": true,
		"baseUrl": "/home/joshrm/Documentos/proyectos/peruintercorp/conasin/template-nestjs-dashboard-better_auth",
		"paths": {
			"@/src/*": [
				"src/*"
			],
			"@/app/*": [
				"src/app/*"
			],
			"@/contexts/*": [
				"src/contexts/*"
			],
			"@/shared/*": [
				"src/shared/*"
			],
			"@/tests/*": [
				"tests/*"
			]
		}
	},
	"module": {
		"type": "es6",
		"strict": true,
		"strictMode": true,
		"noInterop": false
	},
	"minify": false
}
